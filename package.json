    "ink": "^5.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
