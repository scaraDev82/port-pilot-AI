{
  "name": "port-pilot-ai",
  "version": "0.1.0",
  "description": "CLI for inspecting and managing listening ports on your machine.",
  "type": "module",
  "bin": {
    "ports": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
